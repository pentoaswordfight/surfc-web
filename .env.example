# Surfc marketing site env vars
# Copy to .env.local (gitignored) for local dev; set these in the Cloudflare
# Pages dashboard for production builds.

# Public anon key — required because the Supabase gateway requires an
# `apikey` header even on verify_jwt=false functions (used by the /pricing
# page's create-checkout-session call). This is safe to expose; it grants
# only the permissions of the `anon` Postgres role, which RLS pins.
PUBLIC_SUPABASE_ANON_KEY=

# Supabase project URL (e.g. https://xxxx.supabase.co). Used by the /pricing
# page (SUR-86) to call create-checkout-session via the canonical
# `${PUBLIC_SUPABASE_URL}/functions/v1/create-checkout-session` URL pattern.
PUBLIC_SUPABASE_URL=https://klwxefgzzbwvzwsybkpx.supabase.co

# Where the app shell lives. All "Sign up free" / "Sign in" / "Open the app"
# CTAs point here.
PUBLIC_APP_URL=https://app.surfc.app

# Shared with the main app's PostHog project so we can track the full funnel
# from landing → app sign-up.
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
