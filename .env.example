# Surfc marketing site env vars
# Copy to .env.local (gitignored) for local dev; set these in the Netlify
# dashboard for production builds.

# The public URL of the Supabase Edge Function that handles waitlist signups.
# Deployed from the main surfc repo: supabase/functions/waitlist-signup/
PUBLIC_WAITLIST_ENDPOINT=https://klwxefgzzbwvzwsybkpx.functions.supabase.co/waitlist-signup

# Public anon key — required because the Supabase gateway still requires an
# `apikey` header even on verify_jwt=false functions. This is safe to expose;
# it grants only the permissions of the `anon` Postgres role, which RLS pins.
PUBLIC_SUPABASE_ANON_KEY=

# Supabase project URL (e.g. https://xxxx.supabase.co). Used by the /pricing
# page (SUR-86) to call create-checkout-session via the canonical
# `${PUBLIC_SUPABASE_URL}/functions/v1/create-checkout-session` URL pattern.
# Same project as PUBLIC_WAITLIST_ENDPOINT — only the URL shape differs.
PUBLIC_SUPABASE_URL=https://klwxefgzzbwvzwsybkpx.supabase.co

# Where the app shell lives. All "Sign in" / "Open the app" CTAs point here.
PUBLIC_APP_URL=https://app.surfc.app

# Shared with the main app's PostHog project so we can track the full funnel
# from landing → waitlist → sign-up.
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
