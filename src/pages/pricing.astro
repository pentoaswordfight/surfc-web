---
/**
 * /pricing — Plans & Pricing page (SUR-86).
 *
 * Static composition of:
 *   - Nav (modified to include the Pricing link)
 *   - PricingHero (hero band with headline + headline CTA)
 *   - PricingTiers (segmented monthly/annual control + Reader / Annotator / Scholar)
 *   - PricingFaq (two questions: cancel, student discounts)
 *   - ClosingCta (reused unchanged)
 *   - Footer
 *
 * The cold-visitor variant is shipped in the static HTML. The hydration
 * lives in `src/scripts/pricingCheckout.ts` (invoked below): it reads the
 * cross-domain access cookie issued by app.surfc.app and, when present, swaps
 * the hero / Annotator CTA copy and rebinds the Annotator CTA to call
 * `create-checkout-session` directly — saving the round-trip through
 * `app.surfc.app/upgrade`. It also drives the SUR-466 loading/timeout overlay
 * and the SUR-496 failure banner (both rendered hidden by
 * <StripeCheckoutStates />). See the plan in
 * .claude/plans/sur-86-sur-235-defines-the-fluttering-locket.md for the
 * original auth-hydration architecture.
 */

import BaseLayout           from '../layouts/BaseLayout.astro'
import Nav                  from '../components/Nav.astro'
import PricingHero          from '../components/PricingHero.astro'
import PricingTiers         from '../components/PricingTiers.astro'
import PricingFaq           from '../components/PricingFaq.astro'
import ClosingCta           from '../components/ClosingCta.astro'
import Footer               from '../components/Footer.astro'
import StripeCheckoutStates from '../components/StripeCheckoutStates.astro'
import { TIER_NAMES }       from '../lib/tiers.ts'

import '../styles/pricing.css'
---

<BaseLayout
  title="Plans & Pricing — Surfc"
  description={`Surfc ${TIER_NAMES.free} is generous enough to build a real reading index. Surfc ${TIER_NAMES.pro} keeps it alive as your reading evolves. $8.99/month or $79/year — annual saves 27%.`}
  ogImage="/og-pricing.jpg"
  path="/pricing/"
>
  <Nav />
  <main id="main">
    <PricingHero />
    <StripeCheckoutStates />
    <PricingTiers />
    <PricingFaq />
    <ClosingCta />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Auth-aware hydration + Stripe hand-off states (SUR-86 / SUR-466 / SUR-496).
  // All orchestration lives in the module so it stays testable and the spine
  // pricing page keeps a thin entry point.
  import { initPricingCheckout } from '../scripts/pricingCheckout.ts'
  initPricingCheckout()
</script>
