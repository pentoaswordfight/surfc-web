---
/**
 * Privacy Policy (SUR-618) — rendered from in-repo markdown, replacing the
 * Termly embed. Static HTML (crawlable, no noindex/CLS).
 *
 * The policy text is duplicated from `surfc/src/policies/privacy.md` — there is
 * no shared artifact across the two repos, so keep them in lockstep (same
 * PRICE_COPY / UTM pattern). The only intended divergence is internal-link
 * trailing slashes, required here by `trailingSlash: 'always'`.
 *
 * The Termly consent banner stays in BaseLayout (resource-blocker) — that
 * migrates to Klaro under SUR-620 and Termly is decommissioned last (SUR-621).
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import { Content as PrivacyDoc } from '../../policies/privacy.md'
import '../../styles/policy.css'
---

<BaseLayout
  title="Privacy Policy — Surfc"
  description="How Surfc handles the notes, photos, and metadata you store with us."
  path="/policies/privacy"
>
  <div class="policy-page" data-policy="privacy">
    <header class="policy-header">
      <a class="policy-back-link" href="/">← Back to Surfc</a>
    </header>
    <main class="policy-content">
      <PrivacyDoc />
    </main>
  </div>
</BaseLayout>
