---
/**
 * Terms of Use (SUR-619) — rendered from in-repo markdown, replacing the Termly
 * embed. Static HTML (crawlable, no noindex/CLS).
 *
 * Policy text is duplicated from `surfc/src/policies/terms.md` — keep in
 * lockstep (no shared artifact across repos). Only intended divergence is
 * internal-link trailing slashes (`trailingSlash: 'always'`).
 *
 * Termly consent banner stays in BaseLayout (SUR-620 Klaro / SUR-621 removal).
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import { Content as TermsDoc } from '../../policies/terms.md'
import '../../styles/policy.css'
---

<BaseLayout
  title="Terms of Use — Braird"
  description="The terms under which Surfc is offered."
  path="/policies/terms"
>
  <div class="policy-page" data-policy="terms">
    <header class="policy-header">
      <a class="policy-back-link" href="/">← Back to Braird</a>
    </header>
    <main class="policy-content">
      <TermsDoc />
    </main>
  </div>
</BaseLayout>
