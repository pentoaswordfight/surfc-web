---
/**
 * Braird front door (SUR-679, copy SUR-727). A forest-ground hero, four verb
 * sections (Resurface → Connect → Compound → Create) each lit on the taxonomy
 * eyebrow, and a quiet close that carries the encryption/sync reassurance
 * above its CTA. The interim "What Braird is" explainer (SUR-709, for Google's
 * OAuth review — now complete) has been retired.
 *
 * Design lives in src/styles/braird.css; the body opts into the forest
 * treatment via `braird-front-door`.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav        from '../components/Nav.astro'
import Hero       from '../components/braird/Hero.astro'
import Beats      from '../components/braird/Beats.astro'
import Close      from '../components/braird/Close.astro'
import Footer     from '../components/Footer.astro'
---

<BaseLayout
  title="Braird — turn scattered notes into connected thinking"
  description="Braird brings your highlights, scraps, and reflections together so related ideas resurface when you need them — for writing, research, and creative work."
  ogImage="/braird-og-connect.png"
  bodyClass="braird-front-door"
>
  <Nav />
  <Hero />
  <Beats />
  <Close />
  <Footer />
</BaseLayout>
