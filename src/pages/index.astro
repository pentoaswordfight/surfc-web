---
/**
 * Braird front door (SUR-679). Stripped right down: a forest-ground hero
 * (the four-verb taxonomy with CONNECT lit), three supporting verb beats, and
 * a quiet close. The old explanatory sections moved to /how-it-works/.
 *
 * Design lives in src/styles/braird.css; the body opts into the forest
 * treatment via `braird-front-door`.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav        from '../components/Nav.astro'
import Hero       from '../components/braird/Hero.astro'
import Beats      from '../components/braird/Beats.astro'
import Close      from '../components/braird/Close.astro'
import Footer     from '../components/Footer.astro'
---

<BaseLayout
  title="braird — every note finds its kin"
  description="braird turns the books you read into a living index of ideas. Resurface, connect, compound, and create — so the next time you sit down to write, you're not starting from a blank page."
  ogImage="/braird-og-connect.png"
  bodyClass="braird-front-door"
>
  <Nav />
  <Hero />
  <Beats />
  <Close />
  <Footer />
</BaseLayout>
