---
/**
 * Braird front-door hero (SUR-679, copy SUR-727). A left-aligned Lora headline
 * over the brand illustration in the right column — a book sprouting an idea,
 * threads connecting it to notes, a stack of books, and a phone. Its own ground
 * is the forest, so the edges are feathered (mask) to dissolve into the page
 * rather than end in a hard frame. The four-verb taxonomy eyebrow now lives on
 * each section beat (Beats.astro), not here.
 */
import { signupUrl } from '../../lib/appUrl'
---

<header class="bf-hero bf-dots">
  <span class="bf-hero-glow" aria-hidden="true"></span>
  <div class="bf-wrap">
    <div class="bf-hero-copy">
      <h1 class="bf-hero-title">
        Turn scattered notes into <span class="bf-accent">connected thinking</span>.
      </h1>
      <p class="bf-hero-sub">Braird brings your highlights, scraps, and reflections together so related ideas can resurface when they matter.</p>

      <div class="bf-cta-row">
        <a href={signupUrl()} class="bf-cta" data-cta="hero_signup">
          Open braird
        </a>
      </div>
    </div>

    <figure class="bf-hero-art">
      <img
        src="/braird-hero.webp"
        alt="An open book on a desk sprouting a seedling, glowing green threads linking it to a stack of books, handwritten notes, and a phone playing an audiobook."
        width="1400"
        height="788"
        fetchpriority="high"
        decoding="async"
      />
    </figure>
  </div>
</header>
