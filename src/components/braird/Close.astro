---
/**
 * Braird front-door close (SUR-679). Wordmark lockup + a single promise line,
 * the encryption/sync trust line (SUR-727, relocated from the retired
 * explainer), and the one CTA. Closing copy is the founder's line, not an OG card.
 */
import { signupUrl } from '../../lib/appUrl'
import Wordmark from './Wordmark.astro'
---

<section class="bf-close bf-dots">
  <span class="bf-hero-glow" aria-hidden="true"></span>
  <div class="bf-wrap">
    <Wordmark class="bf-close-lockup" />
    <p class="bf-close-def">
      <span class="bf-ipa">/brɛːrd/</span> — the first green shoots after sowing
    </p>
    <p class="bf-close-line">
      You never have to start from a <span class="bf-accent">blank page</span> again.
    </p>
    <p class="bf-close-trust">Your notes are encrypted, kept in your account, and synced across your devices.</p>
    <div class="bf-cta-row">
      <a href={signupUrl()} class="bf-cta" data-cta="closing_signup">
        Open braird
      </a>
    </div>
  </div>
</section>
