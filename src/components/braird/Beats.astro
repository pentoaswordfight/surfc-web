---
/**
 * Braird front-door beats (SUR-679). The verb arc — Create / Compound /
 * Resurface, top to bottom — each its own Lora line, copy lifted verbatim from
 * the brand OG cards. The brand illustration now leads the hero; the beats are
 * a clean, typographic arc beneath it.
 */
---

<section class="bf-beats bf-dots" aria-label="What braird does">
  <div class="bf-wrap">
    <ol class="bf-beat-list">
      <li class="bf-beat">
        <p class="bf-beat-verb">Create</p>
        <div class="bf-beat-body">
          <h2 class="bf-beat-title">Fragments become <span class="bf-accent">something new</span>.</h2>
          <p class="bf-beat-sub">Note scraps, book highlights and podcast snips come together to fuel your creative process.</p>
        </div>
      </li>
      <li class="bf-beat">
        <p class="bf-beat-verb">Compound</p>
        <div class="bf-beat-body">
          <h2 class="bf-beat-title">Reading that <span class="bf-accent">adds up</span> over time.</h2>
          <p class="bf-beat-sub">Knowledge, with interest.</p>
        </div>
      </li>
      <li class="bf-beat">
        <p class="bf-beat-verb">Resurface</p>
        <div class="bf-beat-body">
          <h2 class="bf-beat-title">The right idea, <span class="bf-accent">back</span> when you need it.</h2>
          <p class="bf-beat-sub">Read, write, listen. Save it all to braird and let serendipity happen.</p>
        </div>
      </li>
    </ol>
  </div>
</section>
