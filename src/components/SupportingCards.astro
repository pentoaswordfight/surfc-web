---
// Port source: surfc/src/components/LandingPage.jsx lines 322-336.
// SUR-679 — section reframed around connecting across reading sources.

// Reading sources braird pulls highlights + notes in from.
const INTEGRATIONS = ['Kindle', 'Kobo', 'Instapaper', 'Readwise']

const SUPPORTING_CARDS = [
  { icon: '📖', label: 'Library & notes',       body: 'Capture by photo or jot insights directly. Every note keeps its page and book attribution.' },
  { icon: '⟳',  label: 'Sync across devices',   body: 'Notes live locally first and sync when online.' },
  { icon: '◐',  label: 'Offline-first & private', body: 'Everything works without a connection. End-to-end encryption at rest with AES-256-GCM.' },
]
---

<section class="hiw-section-v2">
  <div class="hiw-threeup">
    <p class="hiw-step-label hiw-step-center">04 · Plus</p>
    <h2 class="hiw-h2 hiw-h2-center">Connect across sources, no matter how you read</h2>
    <ul class="hiw-integrations" aria-label="Reading sources braird connects with">
      {INTEGRATIONS.map((name) => (
        <li class="hiw-integration">
          <span class="hiw-integration-dot" aria-hidden="true"></span>
          {name}
        </li>
      ))}
    </ul>
    <div class="hiw-threeup-grid">
      {SUPPORTING_CARDS.map((card) => (
        <article class="surfc-card hiw-mini-card">
          <div class="hiw-mini-glyph" aria-hidden="true">{card.icon}</div>
          <h3 class="hiw-mini-title">{card.label}</h3>
          <p class="hiw-mini-body">{card.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Integration chips — cool-paper pills with a shoot-green "connected" dot.
     Tokens recolour to the Braird palette automatically. */
  .hiw-integrations {
    list-style: none;
    margin: 0 auto 36px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .hiw-integration {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: var(--radius-chip);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .hiw-integration-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
</style>
