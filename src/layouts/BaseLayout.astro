---
/**
 * BaseLayout — shared <head> and <body> chrome for every marketing page.
 *
 * Responsibilities:
 *   - Meta tags (SEO, viewport, theme, OG, Twitter)
 *   - Font preconnect + Google Fonts (matches the app's current load)
 *   - Termly resource-blocker (GDPR consent banner, same resource ID as
 *     the legacy index.html so returning visitors keep their choice)
 *   - Canonical URL derived from the requested path
 *
 * Port sources:
 *   - surfc/index.html — meta tags, fonts, Termly blocker
 *   - SUR-218 plan — OG image + Twitter card requirements
 */

import '../styles/tokens.css'
import '../styles/fonts.css'
import '../styles/marketing.css'

interface Props {
  title?:       string
  description?: string
  ogImage?:     string
  path?:        string
  noindex?:     boolean
  nofollow?:    boolean
  bodyClass?:   string
  /**
   * Body-level data attributes. Keys are emitted as `data-${key}` and must
   * already be kebab-case (e.g. `'blog-slug'` → `data-blog-slug`). Browsers
   * normalise camelCase to lowercase, breaking `dataset.blogSlug` reads,
   * so the normalisation must happen at the call site.
   */
  bodyData?:    Record<string, string | number>
}

const {
  title       = 'Surfc — a personal index of great ideas',
  description = "Surfc turns a lifetime of reading into something you can actually think with. Capture printed passages and handwritten notes; tag them to 102 canonical ideas or your own.",
  ogImage     = '/og-image.png',
  path        = Astro.url.pathname,
  noindex     = false,
  nofollow    = false,
  bodyClass   = 'lp-page-v2',
  bodyData    = {},
} = Astro.props

const robotsParts: string[] = []
if (noindex)  robotsParts.push('noindex')
if (nofollow) robotsParts.push('nofollow')
const robotsContent = robotsParts.join(', ')

const canonical = new URL(path, Astro.site ?? 'https://surfc.app').toString()
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://surfc.app').toString()

// PostHog — same project as the React app so we get the landing → app sign-up
// funnel in one stream. Token may be empty locally; the init guard below
// no-ops in that case.
const posthogToken = import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN ?? ''
const posthogHost  = import.meta.env.PUBLIC_POSTHOG_HOST          ?? 'https://eu.i.posthog.com'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FFF8F2" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {robotsContent && <meta name="robots" content={robotsContent} />}

    <title>{title}</title>

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Surfc" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@surfcapp" />
    <meta name="twitter:creator" content="@surfcapp" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: self-hosted via @fontsource/* (see src/styles/fonts.css).
         font-display:optional suppresses CLS — no swap shift on load. -->

    <!-- Termly resource blocker (GDPR consent) — same resource ID as the app -->
    <script src="https://app.termly.io/resource-blocker/135b750f-a45d-4fbb-91c6-0f8e1c0b6b8d?autoBlock=on" is:inline></script>

    <!-- PostHog — shares the React app's project so the landing → app sign-up
         funnel lives in a single stream. Termly auto-blocks until consent. -->
    <script is:inline define:vars={{ posthogToken, posthogHost }}>
      if (posthogToken) {
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(posthogToken, {
          api_host: posthogHost,
          capture_pageview: true,
          session_recording: { maskAllInputs: true },
        });
        // Global CTA-click attribution. Fires on capture phase so the event is
        // queued before the browser navigates away. SUR-367 adds an additive
        // `marketing_signup_clicked` capture for every signup-intent CTA so
        // the new conversion funnel anchors on a single step-1 event without
        // disturbing existing dashboards built on `app_cta_clicked`.
        //
        // Pricing-page CTAs are included: `pricing_start_free` and
        // `pricing_hero_start_free` are direct signup intents, and
        // `pricing_get_pro_annual` requires account creation before
        // checkout (cold visitors hit UpgradeAuthGate first), so it
        // anchors the same signup funnel.
        var SIGNUP_CTAS = {
          nav_signup:              1,
          hero_signup:             1,
          closing_signup:          1,
          pricing_start_free:      1,
          pricing_hero_start_free: 1,
          pricing_get_pro_annual:  1,
        };
        document.addEventListener('click', function (event) {
          var target = event.target && event.target.closest ? event.target.closest('[data-cta]') : null;
          if (!target || !window.posthog) return;
          var cta = target.getAttribute('data-cta');
          window.posthog.capture('app_cta_clicked', { cta: cta });
          if (Object.prototype.hasOwnProperty.call(SIGNUP_CTAS, cta)) {
            window.posthog.capture('marketing_signup_clicked', { cta: cta });
          }
        }, true);
      }
    </script>

    <!-- Per-page extras (Article JSON-LD on blog posts, etc.) -->
    <slot name="head" />
  </head>
  <body class={bodyClass} {...Object.fromEntries(Object.entries(bodyData).map(([k, v]) => [`data-${k}`, String(v)]))}>
    <slot />

    <!-- SUR-370 — Forward UTM / click-ID params from the marketing page's
         URL onto cross-domain `app.surfc.app` CTAs so AuthScreen's
         `auth_landing_viewed` event carries campaign attribution. -->
    <script>
      import '../scripts/preserveUtm'
    </script>
  </body>
</html>
