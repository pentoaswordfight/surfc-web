/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Cache-Control: public, max-age=31536000, immutable

/icon-*.png
  Cache-Control: public, max-age=31536000, immutable

/robots.txt
  Cache-Control: public, max-age=86400

# ponytail: extensionless file — CF Pages infers Content-Type from the
# extension, and there isn't one, so the ROR file would ship as text/plain.
# Chrome's Related Origin Requests fetch rejects it unless application/json (SUR-686).
/.well-known/webauthn
  Content-Type: application/json
